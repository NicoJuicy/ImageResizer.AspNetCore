<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Sapico.ImageResizer</id>
    <version>10.0.6</version>
    <authors>Sapico</authors>
    <description>Sapico.ImageResizer is a lightweight, fast image processing middleware for ASP.NET Core. On-the-fly image resizing, cropping, format conversion, and watermarking through URL query parameters.

Forked from: https://github.com/cornelha/ImageResizer.AspNetCore</description>
    <releaseNotes>Initial Sapico fork release. Added width/height query parameter aliases, plugin architecture for caching.</releaseNotes>
    <projectUrl>https://github.com/NicoJuicy/ImageResizer.AspNetCore</projectUrl>
    <repository type="public" url="https://github.com/NicoJuicy/ImageResizer.AspNetCore" />
    <license type="file">LICENSE</license>
    <icon>ImageResizing.png</icon>
    <readme>README.md</readme>
    <dependencies>
      <group targetFramework="net10.0">
        <dependency id="Microsoft.Extensions.Caching.Abstractions" version="10.0.0" />
        <dependency id="Microsoft.Extensions.Caching.Memory" version="10.0.0" />
        <dependency id="Microsoft.Extensions.FileProviders.Physical" version="10.0.0" />
        <dependency id="Microsoft.Extensions.Hosting" version="10.0.0" />
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="10.0.0" />
        <dependency id="Newtonsoft.Json" version="13.0.4" />
        <dependency id="SkiaSharp" version="3.119.1" />
        <dependency id="SkiaSharp.NativeAssets.Linux.NoDependencies" version="3.119.1" />
        <dependency id="System.Configuration.ConfigurationManager" version="10.0.0" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="bin\Release\net10.0\Sapico.ImageResizer.dll" target="lib\net10.0" />
    <file src="bin\Release\net10.0\Sapico.ImageResizer.pdb" target="lib\net10.0" />
    <file src="..\LICENSE" target="" />
    <file src="ImageResizing.png" target="" />
    <file src="README.md" target="\" />
  </files>
</package>
